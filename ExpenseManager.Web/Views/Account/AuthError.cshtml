@{
    Layout = null;
    ViewData["Title"] = "Authentication Error";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ExpenseManager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.10.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="height: 100vh;">
    <div class="custom-card col-md-4 shadow-lg p-5 text-center">
        <div class="mb-4">
            <div class="logo-box d-inline-block mb-3" style="background: #1e293b; color: white; padding: 10px 15px; border-radius: 12px; font-weight: bold; font-size: 1.5rem;">Fd</div>
        </div>
        <div class="mb-4">
            <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 3rem;"></i>
        </div>
        <h4 class="fw-bold mb-3">Authentication Error</h4>
        <p class="text-muted small mb-4">@(ViewData["ErrorMessage"] ?? "An error occurred during authentication. Please try again or contact your administrator.")</p>
        <a href="@Url.Action("Login", "Account")" class="btn btn-primary w-100 py-2 fw-bold" style="background-color: #1e3a8a; border: none; border-radius: 8px;">
            <i class="bi bi-arrow-left me-1"></i> Back to sign in
        </a>
    </div>
</body>
</html>
