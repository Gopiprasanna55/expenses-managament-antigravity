@{
    Layout = null;
    ViewData["Title"] = "Access Denied";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ExpenseManager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            height: 100vh;
            overflow: hidden;
        }
        .error-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            border-radius: 24px;
            max-width: 500px;
            width: 90%;
            transition: transform 0.3s ease;
        }
        .error-card:hover {
            transform: translateY(-5px);
        }
        .illustration {
            max-width: 280px;
            filter: drop-shadow(0 10px 15px rgba(0,0,0,0.1));
        }
        .brand-pill {
            background: #1e293b;
            color: white;
            padding: 8px 16px;
            border-radius: 50px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 2rem;
        }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center">
    <div class="error-card shadow-2xl p-5 text-center">
        <!-- <div class="brand-pill shadow-sm">
            <span style="background: white; color: #1e293b; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 0.8rem;">Fd</span>
            ExpenseManager
        </div> -->
         <div class="sidebar-header  d-flex justify-content-center pb-2">
                <!-- <img src="~/logo-removebg-preview.png" alt="Logo" style="max-height: 45px; width: auto;" /> -->
                <img src="https://fdestech.com/images/logo.png" alt="Logo" style="max-height: 45px; width: auto;" />
            </div>


        
        <div class="mb-4">
            <img src="/images/unauthorized_illustration.png" alt="Unauthorized" class="illustration img-fluid rounded-4" />
        </div>

        <h2 class="fw-bold text-dark mb-2">Access Restricted</h2>
        <p class="text-muted mb-4 px-3" style="font-size: 1.1rem; line-height: 1.6;">
            @(ViewData["ErrorMessage"] ?? "you are unauthorized Contact administrator.")
        </p>

        <div class="d-grid gap-3">
            <a href="@Url.Action("Login", "Account")" class="btn btn-primary py-3 fw-bold shadow-sm" style="background: #1e293b; border: none; border-radius: 12px; font-size: 1rem;">
                <i class="bi bi-arrow-left-circle me-2"></i> Return to Login
            </a>
            <p class="small text-muted mb-0">If you believe this is an error, please reach out to your IT department.</p>
        </div>
    </div>
</body>
</html>
