@using ExpenseManager.Web.ViewModels
@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Sign In";
    var returnUrl = ViewData["ReturnUrl"]?.ToString();
    var authError = ViewData["AuthError"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ExpenseManager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; background: #f8fafc; color: #1e293b; }
        .login-wrapper { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 1.5rem; }
        .login-card {
            background: #fff; border-radius: 20px; padding: 2.5rem;
            width: 100%; max-width: 440px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.04), 0 2px 10px rgba(0,0,0,0.02);
            border: 1px solid #f1f5f9;
        }
        .logo-container {
            /* width: 163px; height: 58px; background: #1e293b; color: #fff; */
             width: 163px; height: 58px; color: #fff;
            border-radius: 14px; font-weight: 800; font-size: 1.5rem;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 0.5rem;
        }
        .form-control { border-radius: 12px; padding: 0.75rem 1rem; border: 1px solid #e2e8f0; }
        .form-control:focus { border-color: #1e293b; box-shadow: none; }
        .btn-primary { 
            background: #1e293b; border: none; border-radius: 12px; padding: 0.75rem 1rem; 
            font-weight: 600; width: 100%; transition: all 0.2s;
        }
        .btn-primary:hover { background: #0f172a; transform: translateY(-1px); }
        .btn-microsoft {
            background: #fff; color: #5e5e5e; border: 1px solid #8c8c8c;
            border-radius: 12px; padding: 0.75rem 1rem; font-weight: 500;
            width: 100%; display: flex; align-items: center; justify-content: center;
            gap: 10px; transition: all 0.2s;
        }
        .btn-microsoft:hover { background: #f3f3f3; border-color: #5e5e5e; transform: translateY(-1px); }
        .divider { display: flex; align-items: center; text-align: center; margin: 0.5rem 0; color: #94a3b8; font-size: 0.8rem; }
        .divider::before, .divider::after { content: ''; flex: 1; border-bottom: 1px solid #e2e8f0; }
        .divider:not(:empty)::before { margin-right: .75em; }
        .divider:not(:empty)::after { margin-left: .75em; }
        .auth-status-alert {
            border-radius: 12px; padding: 14px 18px; font-size: 0.9rem;
            display: flex; align-items: flex-start; gap: 12px; margin-bottom: 1.5rem;
        }
        .alert-error { background: #fff1f2; border: 1px solid #fecdd3; color: #be123c; }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">
            <div class="logo-container">
             <img src="https://fdestech.com/images/logo.png" alt="Logo" style="max-height: 56px; width: auto;" />
            </div>
            
            <div class="text-center mb-4">
                <h4 class="fw-bold mb-1">Expense Management</h4>
                <p class="text-muted small">Choose your preferred sign-in method</p>
            </div>

            @if (!string.IsNullOrEmpty(authError) || !ViewData.ModelState.IsValid) {
                <div class="auth-status-alert alert-error">
                    <i class="bi bi-exclamation-circle-fill mt-0.5"></i>
                    <div>
                        @if (!string.IsNullOrEmpty(authError)) {
                            <p class="mb-0">@authError</p>
                        }
                        <div asp-validation-summary="All" class="text-danger small"></div>
                    </div>
                </div>
            }

            <form asp-action="Login" asp-controller="Account" asp-route-returnUrl="@returnUrl" method="post">
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Email Address</label>
                    <input asp-for="Email" class="form-control" placeholder="name@company.com" required />
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label class="form-label small fw-semibold mb-0">Password</label>
                    </div>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" required />
                </div>
                <div class="mb-4 d-flex align-items-center">
                    <input asp-for="RememberMe" type="checkbox" class="form-check-input me-2" id="rememberMe" />
                    <label class="form-check-label small text-muted" for="rememberMe">Remember for 30 days</label>
                </div>
                <button type="submit" class="btn btn-primary">Sign In</button>
            </form>

            <div class="divider">OR</div>

            <a asp-action="MicrosoftLogin" asp-controller="Account" asp-route-returnUrl="@returnUrl" class="btn btn-microsoft">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 23 23">
                    <path fill="#f3f3f3" d="M0 0h23v23H0z"/>
                    <path fill="#f35325" d="M1 1h10v10H1z"/>
                    <path fill="#81bc06" d="M12 1h10v10H12z"/>
                    <path fill="#05a6f0" d="M1 12h10v10H1z"/>
                    <path fill="#ffba08" d="M12 12h10v10H12z"/>
                </svg>
                Sign in with Microsoft
            </a>
        </div>
    </div>
</body>
</html>
