@using System.Web
@using System.Security.Claims
@model IEnumerable<ExpenseManager.Application.DTOs.UserDto>
@{
    ViewData["Title"] = "User Management";
    var callerRole = ViewData["CallerRole"]?.ToString() ?? "Admin";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0">User Management</h3>
            <p class="text-muted small mb-0">Manage roles and account access for all staff</p>
        </div>
        @if (callerRole == "SuperAdmin" || callerRole == "Admin")
        {
            <a asp-action="AddEmployee" class="btn btn-teal d-flex align-items-center gap-2">
                <i class="bi bi-person-plus"></i> Add Employee
            </a>
        }
    </div>


    <div class="standard-table-container">
        <div class="table-body-scroll-limit">
            <table class="standard-table ">
            <thead>
                <tr>
                    <th>User Information</th>
                    <th>Email Address</th>
                    <th>Account Role</th>

                    <th>Created On</th>
                     @if (callerRole != "HR")
                    {
                        <th class="text-center">Account Status</th>
                    }else{
                        <th class="text-center">Account Status</th>
                    }
                    @if (callerRole != "HR")
                    {
                        <th class="text-center" style="width: 150px;">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-teal">
                                        @string.Concat(user.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(n => n[0])).ToUpper()
                                    </div>
                                    <span class="fw-bold text-dark">@user.FullName</span>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge-pill-standard @(user.Role == "SuperAdmin" ? "badge-pending" : "badge-active")">
                                    <span class="dot"></span>
                                    @user.Role
                                </span>
                            </td>
                            <td class="text-muted">@user.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td class="text-center">
                                <span class="badge-pill-standard @(user.IsActive ? "badge-active" : "badge-inactive")">
                                    <span class="dot"></span>
                                    @(user.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            @if (callerRole != "HR")
                            {
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        @if (callerRole == "SuperAdmin" || (callerRole == "Admin" && user.Role == "HR"))
                                        {
                                            var isCurrentUser = User.FindFirstValue(ClaimTypes.NameIdentifier) == user.Id || User.Identity?.Name == user.Email;
                                            
                                            @if (!isCurrentUser)
                                            {
                                                <button type="button" class="btn-icon-circle" title="Edit" 
                                                        onclick="editUser({ 
                                                            id: '@user.Id', 
                                                            fullName: '@HttpUtility.JavaScriptStringEncode(user.FullName)', 
                                                            email: '@HttpUtility.JavaScriptStringEncode(user.Email)', 
                                                            role: '@user.Role', 
                                                            isActive: @(user.IsActive.ToString().ToLower()) 
                                                        })">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                            
                                                <div class="form-check form-switch d-inline-block align-middle me-2">
                                                    <input class="form-check-input custom-switch cursor-pointer" type="checkbox" 
                                                           @(user.IsActive ? "checked" : "") 
                                                           title="@(user.IsActive ? "Deactivate" : "Activate")"
                                                           onchange="handleToggleStatus('@user.Id', this.checked, '@HttpUtility.JavaScriptStringEncode(user.FullName)')">
                                                </div>

                                                <button type="button" class="btn-icon-circle text-danger" title="Delete" 
                                                        onclick="confirmDeleteUser('@user.Id', '@HttpUtility.JavaScriptStringEncode(user.FullName)')">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }

                                            @if (callerRole == "SuperAdmin" && !isCurrentUser)
                                            {
                                                <div class="dropdown">
                                                    <button type="button" class="btn-icon-circle" data-bs-toggle="dropdown">
                                                        <i class="bi bi-three-dots-vertical"></i>
                                                    </button>
                                                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm p-1" style="border-radius: 8px;">
                                                        <li>
                                                            <form asp-action="AssignRole" asp-route-id="@user.Id" asp-route-role="SuperAdmin" method="post">
                                                                <button type="submit" class="dropdown-item rounded-2 small @(user.Role == "SuperAdmin" ? "disabled" : "")">Make SuperAdmin</button>
                                                            </form>
                                                        </li>
                                                        <li>
                                                            <form asp-action="AssignRole" asp-route-id="@user.Id" asp-route-role="Admin" method="post">
                                                                <button type="submit" class="dropdown-item rounded-2 small @(user.Role == "Admin" ? "disabled" : "")">Make Admin</button>
                                                            </form>
                                                        </li>
                                                        <li>
                                                            <form asp-action="AssignRole" asp-route-id="@user.Id" asp-route-role="HR" method="post">
                                                                <button type="submit" class="dropdown-item rounded-2 small @(user.Role == "HR" ? "disabled" : "")">Make HR</button>
                                                            </form>
                                                        </li>
                                                    </ul>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted small"></span>
                                        }
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="pagination-container rounded-bottom shadow-sm">
        <div class="small fw-medium text-muted" id="userPaginationInfo">
            Showing 1-10 of 100 entries
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center gap-2 me-4">
                <span class="small text-muted fw-medium">Rows per page:</span>
                <select id="userPageSizeSelect" class="form-select form-select-sm border-0 bg-light" style="width: 70px; border-radius: 6px;">
                    <option value="10" selected>10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                </select>
            </div>
            <div class="d-flex gap-1" id="userPaginationControls">
            </div>
        </div>
    </div>
</div>


<!-- Edit User Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title modal-title-custom">Edit Employee</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editUserForm" asp-action="Edit" method="post">
                <input type="hidden" name="Id" id="editUserId" />
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">FULL NAME</label>
                        <input type="text" name="FullName" id="editFullName" class="form-control form-control-custom" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">EMAIL ADDRESS</label>
                        <input type="email" name="Email" id="editEmail" class="form-control form-control-custom" required />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">ROLE</label>
                            <select name="Role" id="editRole" class="form-select form-control-custom">
                                @if (callerRole == "SuperAdmin")
                                {
                                    <option value="SuperAdmin">SuperAdmin</option>
                                    <option value="Admin">Admin</option>
                                    <option value="HR">HR</option>
                                }
                                else
                                {
                                    <option value="HR">HR</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" name="IsActive" id="editIsActive" value="true">
                                <label class="form-check-label small fw-bold text-muted" for="editIsActive">IS ACTIVE</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer modal-footer-custom">
                    <button type="button" class="btn btn-modal-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-modal-primary">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Toggle Status Confirmation Modal -->
<div class="modal fade" id="toggleStatusModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title modal-title-custom" id="toggleStatusTitle">Confirm Action</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="toggleStatusForm" asp-action="ToggleStatus" method="post">
                <input type="hidden" name="id" id="toggleStatusId" />
                <div class="modal-body p-4">
                    <p class="mb-0" id="toggleStatusMessage"></p>
                </div>
                <div class="modal-footer modal-footer-custom">
                    <button type="button" class="btn btn-modal-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="toggleStatusBtn" class="btn px-4">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete User Confirmation Modal -->
<div class="modal fade" id="deleteUserModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title modal-title-custom">Confirm Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="deleteUserForm" asp-action="Delete" method="post">
                <input type="hidden" name="id" id="deleteUserId" />
                <div class="modal-body p-4">
                    <p class="mb-0">Are you sure you want to delete <strong id="deleteUserName"></strong>? This action cannot be undone.</p>
                </div>
                <div class="modal-footer modal-footer-custom">
                    <button type="button" class="btn btn-modal-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-modal-danger px-4">Delete Permanently</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const editUserModal = new bootstrap.Modal(document.getElementById('editUserModal'));
        const toggleStatusModal = new bootstrap.Modal(document.getElementById('toggleStatusModal'));
        const deleteUserModal = new bootstrap.Modal(document.getElementById('deleteUserModal'));

        function editUser(data) {
            document.getElementById('editUserId').value = data.id;
            document.getElementById('editFullName').value = data.fullName;
            document.getElementById('editEmail').value = data.email;
            document.getElementById('editRole').value = data.role;
            document.getElementById('editIsActive').checked = data.isActive;
            editUserModal.show();
        }

        function handleToggleStatus(id, newStatus, name) {
            document.getElementById('toggleStatusId').value = id;
            document.getElementById('toggleStatusTitle').textContent = !newStatus ? 'Deactivate User' : 'Activate User';
            document.getElementById('toggleStatusMessage').innerHTML = `Are you sure you want to <strong>${!newStatus ? 'deactivate' : 'activate'}</strong> <strong>${name}</strong>?`;
            
            const btn = document.getElementById('toggleStatusBtn');
            btn.className = 'btn px-4 ' + (!newStatus ? 'btn-warning' : 'btn-success');
            btn.textContent = !newStatus ? 'Deactivate' : 'Activate';
            
            // If user cancels, we need to revert the switch
            const toggleStatusModalEl = document.getElementById('toggleStatusModal');
            const onHide = () => {
                // Find the checkbox and reset it if we didn't submit
                const checkboxes = document.querySelectorAll('.custom-switch');
                checkboxes.forEach(cb => {
                    if (cb.onclick?.toString().includes(id) || cb.onchange?.toString().includes(id)) {
                        cb.checked = !newStatus;
                    }
                });
                toggleStatusModalEl.removeEventListener('hidden.bs.modal', onHide);
            };
            toggleStatusModalEl.addEventListener('hidden.bs.modal', onHide);

            toggleStatusModal.show();
        }


        function confirmDeleteUser(id, name) {
            document.getElementById('deleteUserId').value = id;
            document.getElementById('deleteUserName').textContent = name;
            deleteUserModal.show();
        }

        let userRowsPerPage = 10;
        let userCurrentPage = 1;
        let allUserRows = [];

        function initUserPagination() {
            allUserRows = Array.from(document.querySelectorAll('.standard-table tbody tr'));
            renderUserRows();
            updateUserPagination();
        }

        document.getElementById('userPageSizeSelect').addEventListener('change', function() {
            userRowsPerPage = parseInt(this.value);
            userCurrentPage = 1;
            renderUserRows();
            updateUserPagination();
        });

        function renderUserRows() {
            const start = (userCurrentPage - 1) * userRowsPerPage;
            const end = start + userRowsPerPage;
            
            allUserRows.forEach((row, index) => {
                if (index >= start && index < end) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        }

        function updateUserPagination() {
            const totalPages = Math.ceil(allUserRows.length / userRowsPerPage) || 1;
            const controls = document.getElementById('userPaginationControls');
            controls.innerHTML = '';

            const prevBtn = document.createElement('button');
            prevBtn.className = `page-btn ${userCurrentPage === 1 ? 'disabled' : ''}`;
            prevBtn.innerHTML = '<i class="bi bi-chevron-left"></i> Previous';
            prevBtn.disabled = userCurrentPage === 1;
            prevBtn.onclick = () => goToUserPage(userCurrentPage - 1);
            controls.appendChild(prevBtn);
            for (let i = 1; i <= totalPages; i++) {
                const pageBtn = document.createElement('button');
                pageBtn.className = `page-btn ${i === userCurrentPage ? 'active' : ''}`;
                pageBtn.textContent = i;
                pageBtn.onclick = () => goToUserPage(i);
                controls.appendChild(pageBtn);
            }

            const nextBtn = document.createElement('button');
            nextBtn.className = `page-btn ${userCurrentPage === totalPages ? 'disabled' : ''}`;
            nextBtn.innerHTML = 'Next <i class="bi bi-chevron-right"></i>';
            nextBtn.disabled = userCurrentPage === totalPages;
            nextBtn.onclick = () => goToUserPage(userCurrentPage + 1);
            controls.appendChild(nextBtn);

            const startIdx = (userCurrentPage - 1) * userRowsPerPage + 1;
            const endIdx = Math.min(userCurrentPage * userRowsPerPage, allUserRows.length);
            document.getElementById('userPaginationInfo').textContent = `Showing ${allUserRows.length > 0 ? startIdx : 0}-${endIdx} of ${allUserRows.length} entries`;
        }

        function goToUserPage(page) {
            const totalPages = Math.ceil(allUserRows.length / userRowsPerPage) || 1;
            if (page < 1 || page > totalPages) return;
            userCurrentPage = page;
            renderUserRows();
            updateUserPagination();
        }

        initUserPagination();
    </script>
}
