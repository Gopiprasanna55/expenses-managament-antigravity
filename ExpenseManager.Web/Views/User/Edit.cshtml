@model ExpenseManager.Application.DTOs.UserUpdateDto
@{
    ViewData["Title"] = "Edit Employee";
    var callerRole = ViewData["CallerRole"]?.ToString() ?? "Admin";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="custom-card">
            <h4 class="fw-bold mb-4 text-center">Edit employee details</h4>
            
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label small fw-bold text-muted">FULL NAME</label>
                    <input asp-for="FullName" class="form-control form-control-custom" required>
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label small fw-bold text-muted">EMAIL ADDRESS</label>
                    <input asp-for="Email" type="email" class="form-control form-control-custom" required>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="Role" class="form-label small fw-bold text-muted">ROLE</label>
                        <select asp-for="Role" class="form-select form-control-custom">
                            @if (callerRole == "SuperAdmin")
                            {
                                <option value="Admin">Admin</option>
                                <option value="HR">HR</option>
                            }
                            else
                            {
                                <option value="HR">HR</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActiveCheck">
                            <label class="form-check-label small fw-bold text-muted" for="isActiveCheck">IS ACTIVE</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-light flex-grow-1 py-2" style="border-radius: 8px;">Cancel</a>
                    <button type="submit" class="btn btn-primary flex-grow-2 py-2" style="background-color: #1e3a8a; border: none; border-radius: 8px; flex: 2;">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>
