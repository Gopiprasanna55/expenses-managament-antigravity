@model ExpenseManager.Application.DTOs.WalletDto
@using ExpenseManager.Application.DTOs
@{
    ViewData["Title"] = "Expense wallet";
    var history = ViewBag.History as IEnumerable<WalletActivityDto>;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">Expense Wallet</h3>
            <p class="text-muted small mb-0">Monitor your budget and manage wallet top-ups</p>
        </div>
    </div>

    <div class="">
        <div class="col-md-12">
            <div class="custom-card h-100">
                <h5 class="fw-bold mb-4">Wallet Balance</h5>
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="fw-bold text-primary mb-0">₹@Model.CurrentBalance.ToString("N2")</h1>
                        <small class="text-muted">Available funds</small>
                    </div>
                    <div>
                        <button type="button" class="btn btn-teal px-4" data-bs-toggle="modal" data-bs-target="#rechargeModal">
                            <i class="bi bi-plus-lg"></i> Recharge Wallet
                        </button>
                    </div>
                </div>

            </div>
        </div>

        <div class="col-md-12">
            <div class="">
            <div class="standard-table-container">
                <table class="standard-table">
                    <thead>
                        <tr>
                            <th>RECHARGE DETAILS</th>
                            <th class="text-end">AMOUNT</th>
                            <th class="text-end" style="width: 120px;">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if(history != null) {
                            foreach(var item in history.Where(x => x.Type == "Recharge").Take(10)) {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            
                                            <div>
                                                <div class="fw-bold text-dark">Wallet Top-up</div>
                                                <small class="text-muted">@item.Date.ToString("dd MMM yyyy")</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-end text-success fw-bold">
                                        +₹@item.Amount.ToString("N2")
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button type="button" class="btn-icon-circle text-primary" onclick="viewRecharge('@item.Id', '@item.Amount', '@item.Date.ToString("yyyy-MM-dd")')" title="View">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            @if (User.IsInRole("Admin")) {
                                                <button type="button" class="btn-icon-circle" onclick="editRecharge('@item.Id', '@item.Amount', '@item.Date.ToString("yyyy-MM-dd")')" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button type="button" class="btn-icon-circle text-danger" onclick="deleteRecharge('@item.Id')" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            </div>
        </div>
    </div>
</div>

<!-- Modals and Scripts -->
<div class="modal fade" id="rechargeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-1" style="border-radius: 12px;">
            <div class="modal-header border-1 pb-2">
                <h5 class="modal-title fw-bold">Recharge Wallet</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Recharge" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">ENTER AMOUNT (₹)</label>
                        <input type="number" step="0.01" name="amount" class="form-control form-control-custom" placeholder="0.00" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">SELECT DATE</label>
                        <input type="date" name="date" class="form-control form-control-custom" value="@DateTime.Now.ToString("yyyy-MM-dd")" required>
                    </div>
                    <p class="small text-muted mb-0">The funds will be added to your available balance immediately.</p>
                </div>
                <div class="modal-footer border-1 pt-2" style="padding:0px">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="padding:3px 4px">Cancel</button>
                    <button type="submit" class="btn btn-teal" style="padding:4px 8px">Confirm</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editRechargeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-1">
            <div class="modal-header border-1 pb-2">            
                <h5 class="modal-title fw-bold">Edit Recharge</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateRecharge" method="post">
                <input type="hidden" name="id" id="editRechargeId" />
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">UPDATE AMOUNT (₹)</label>
                        <input type="number" step="0.01" name="amount" id="editRechargeAmount" class="form-control form-control-custom" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">UPDATE DATE</label>
                        <input type="date" name="date" id="editRechargeDate" class="form-control form-control-custom" required>
                    </div>
                </div>
                <div class="modal-footer border-1 py-1">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="viewRechargeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header border-1 pb-2">
                <h5 class="modal-title fw-bold">Recharge Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="bg-light p-3 rounded-3 mb-3">
                    <div class="row g-3">
                        <div class="col-6">
                            <small class="text-muted d-block">RECHARGE ID</small>
                            <span class="fw-bold" id="viewId">--</span>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">DATE</small>
                            <span class="fw-bold" id="viewDate">--</span>
                        </div>
                        <div class="col-12 mt-3">
                            <small class="text-muted d-block">AMOUNT</small>
                            <span class="fw-bold fs-4 text-success" id="viewAmount">₹0.00</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteRechargeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header border-1 pb-2">
                <h5 class="modal-title fw-bold">Confirm Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="DeleteRecharge" method="post">
                <input type="hidden" name="id" id="deleteRechargeId" />
                <div class="modal-body p-4">
                    <p>Are you sure you want to delete this recharge? The amount will be deducted from your wallet balance.</p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger px-4">Delete Permanently</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1100">
    @if (TempData["Success"] != null) {
        <div class="toast show bg-success text-white" role="alert">
            <div class="d-flex">
                <div class="toast-body">@TempData["Success"]</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function editRecharge(id, amount, date) {
            document.getElementById('editRechargeId').value = id;
            document.getElementById('editRechargeAmount').value = amount;
            document.getElementById('editRechargeDate').value = date;
            new bootstrap.Modal(document.getElementById('editRechargeModal')).show();
        }

        function viewRecharge(id, amount, date) {
            document.getElementById('viewId').textContent = '#' + id;
            document.getElementById('viewAmount').textContent = '₹' + parseFloat(amount).toLocaleString('en-IN', {minimumFractionDigits: 2});
            document.getElementById('viewDate').textContent = date;
            new bootstrap.Modal(document.getElementById('viewRechargeModal')).show();
        }

        function deleteRecharge(id) {
            document.getElementById('deleteRechargeId').value = id;
            new bootstrap.Modal(document.getElementById('deleteRechargeModal')).show();
        }
    </script>
}
