@model ExpenseManager.Application.DTOs.WalletDto
@using ExpenseManager.Application.DTOs
@using System.Web
@{
    ViewData["Title"] = "Expense wallet";
    var history = ViewBag.History as IEnumerable<WalletActivityDto>;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0">Expense Wallet</h3>
            <p class="text-muted small mb-0">Monitor your budget and manage wallet top-ups</p>
        </div>
    </div>

    <div class="">
        <div class="col-md-12">
            <div class="custom-card h-100">
                <!-- <h6 class="fw-bold mb-2">Wallet Balance : ₹@Model.CurrentBalance.ToString("N2")</h6> -->
                <div class="d-flex justify-content-between align-items-center">
                    <!-- <div>
                        <h4 class="fw-bold text-primary mb-0">₹@Model.CurrentBalance.ToString("N2")</h4>
                        <small class="text-muted">Available funds</small>
                    </div> -->
                    <!-- <div>
                          <h6 class="fw-bold mb-2">Wallet Balance :</h6>
                          <span>₹@Model.CurrentBalance.ToString("N2")</span>
                    </div> -->
                    <div>
    <h6 class="fw-bold m-0">
        Wallet Balance :
        <span class="wallet-amount badge bg-primary">₹@Model.CurrentBalance.ToString("N2")</span>
        <span class="text-muted small">Available funds</span>
    </h6>
</div>

<style>
.wallet-amount {
    font-size: 0.85em; /* smaller than the h6 text */
    font-weight: normal; /* optional: make it less bold */
    margin-left: 5px; /* small space after the colon */
}
</style>
                    <div>
                        <button type="button" class="btn btn-teal px-4" data-bs-toggle="modal" data-bs-target="#rechargeModal">
                            <i class="bi bi-plus-lg"></i> Recharge Wallet
                        </button>
                    </div>
                </div>

            </div>
        </div>

        <div class="col-md-12">
            <div class="">
            <div class="standard-table-container">
                <div class="table-body-scroll-limit">
                    <table class="standard-table" style="table-layout: fixed; width: 100%;">
                    <thead>
                        <tr>
                            <th class="text-center" style="width: 5%;">S.No</th>
                            <th style="width: 55%;">Recharge Details</th>
                            <th style="width: 15%;">Date</th>
                            <th class="text-end" style="width: 15%;">Amount</th>
                            <th class="text-end" style="width: 10%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if(history != null) {
                            foreach(var item in history.Where(x => x.Type == "Recharge")) {
                                <tr>
                                    <td class="text-center fw-medium text-muted sno-cell"></td>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            
                                            <div class="text-truncate w-100">
                                                <div class="fw-bold text-dark text-truncate w-100" data-bs-toggle="tooltip" title="Wallet Top-up">Wallet Top-up</div>
                                                @if (!string.IsNullOrEmpty(item.Description))
                                                {
                                                    <div class="text-muted small text-truncate w-100" data-bs-toggle="tooltip" title="@item.Description">@item.Description</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-muted">@item.Date.ToString("dd MMM yyyy")</td>
                                    <td class="text-end text-success fw-bold">
                                        +₹@item.Amount.ToString("N2")
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button type="button" class="btn-icon-circle text-primary d-none" onclick="viewRecharge('@item.Id', '@item.Amount', '@item.Date.ToString("yyyy-MM-dd")')" title="View">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            @if (User.IsInRole("Admin") || User.IsInRole("HR")) {
                                                <button type="button" class="btn-icon-circle" onclick="editRecharge('@item.Id', '@item.Amount', '@item.Date.ToString("yyyy-MM-dd")', '@(HttpUtility.JavaScriptStringEncode(item.Description ?? ""))')" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button type="button" class="btn-icon-circle text-danger" onclick="deleteRecharge('@item.Id')" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                </div>
                <div class="pagination-container rounded-bottom shadow-sm">
                    <div class="small fw-medium text-muted" id="paginationInfo">
                        Showing 1-10 of 100 entries
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="d-flex align-items-center gap-2 me-4">
                            <span class="small text-muted fw-medium">Rows per page:</span>
                            <select id="pageSizeSelect" class="form-select form-select-sm border-0 bg-light" style="width: 70px; border-radius: 6px;">
                                <option value="10" selected>10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                            </select>
                        </div>
                        <div class="d-flex gap-1" id="paginationControls">
                        </div>
                    </div>
                </div>
            </div>
            </div>
        </div>
    </div>
</div>

<!-- Modals and Scripts -->
<div class="modal fade" id="rechargeModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title modal-title-custom">Recharge Wallet</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Recharge" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">ENTER AMOUNT (₹)</label>
                        <input type="number" step="0.01" name="amount" class="form-control form-control-custom" placeholder="0.00" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">SELECT DATE</label>
                        <input type="date" name="date" class="form-control form-control-custom" value="@DateTime.Now.ToString("yyyy-MM-dd")" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">DESCRIPTION (OPTIONAL)</label>
                        <textarea name="description" class="form-control form-control-custom" rows="2" placeholder="Enter recharge details..."></textarea>
                    </div>
                    <p class="small text-muted mb-0">The funds will be added to your available balance immediately.</p>
                </div>
                <div class="modal-footer modal-footer-custom">
                    <button type="button" class="btn btn-modal-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-modal-primary">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editRechargeModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header modal-header-custom">            
                <h5 class="modal-title modal-title-custom">Edit Recharge</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateRecharge" method="post">
                <input type="hidden" name="id" id="editRechargeId" />
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">UPDATE AMOUNT (₹)</label>
                        <input type="number" step="0.01" name="amount" id="editRechargeAmount" class="form-control form-control-custom" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">UPDATE DATE</label>
                        <input type="date" name="date" id="editRechargeDate" class="form-control form-control-custom" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">UPDATE DESCRIPTION</label>
                        <textarea name="description" id="editRechargeDescription" class="form-control form-control-custom" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer modal-footer-custom">
                    <button type="button" class="btn btn-modal-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-modal-primary">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="viewRechargeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title modal-title-custom">Recharge Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="bg-light p-3 rounded-3 mb-3">
                    <div class="row g-3">
                        <div class="col-6">
                            <small class="text-muted d-block">RECHARGE ID</small>
                            <span class="fw-bold" id="viewId">--</span>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">DATE</small>
                            <span class="fw-bold" id="viewDate">--</span>
                        </div>
                        <div class="col-12 mt-3">
                            <small class="text-muted d-block">AMOUNT</small>
                            <span class="fw-bold fs-4 text-success" id="viewAmount">₹0.00</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteRechargeModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title modal-title-custom">Confirm Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="DeleteRecharge" method="post">
                <input type="hidden" name="id" id="deleteRechargeId" />
                <div class="modal-body p-4">
                    <p>Are you sure you want to delete this recharge? The amount will be deducted from your wallet balance.</p>
                </div>
                <div class="modal-footer modal-footer-custom">
                    <button type="button" class="btn btn-modal-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-modal-danger px-4">Delete Permanently</button>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        let rowsPerPage = 10;
        let currentPage = 1;
        let allRows = [];

        function initPagination() {
            allRows = Array.from(document.querySelectorAll('.standard-table tbody tr'));
            filterTable();
        }

        function filterTable() {
            updatePagination();
            renderVisibleRows();
        }

        function updatePagination() {
            const totalPages = Math.ceil(allRows.length / rowsPerPage) || 1;
            const controls = document.getElementById('paginationControls');
            controls.innerHTML = '';

            const prevBtn = document.createElement('button');
            prevBtn.className = `page-btn ${currentPage === 1 ? 'disabled' : ''}`;
            prevBtn.innerHTML = '<i class="bi bi-chevron-left"></i> Previous';
            prevBtn.disabled = currentPage === 1;
            prevBtn.onclick = () => goToPage(currentPage - 1);
            controls.appendChild(prevBtn);

            for (let i = 1; i <= totalPages; i++) {
                const pageBtn = document.createElement('button');
                pageBtn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
                pageBtn.textContent = i;
                pageBtn.onclick = () => goToPage(i);
                controls.appendChild(pageBtn);
            }

            const nextBtn = document.createElement('button');
            nextBtn.className = `page-btn ${currentPage === totalPages ? 'disabled' : ''}`;
            nextBtn.innerHTML = 'Next <i class="bi bi-chevron-right"></i>';
            nextBtn.disabled = currentPage === totalPages;
            nextBtn.onclick = () => goToPage(currentPage + 1);
            controls.appendChild(nextBtn);

            const startIdx = (currentPage - 1) * rowsPerPage + 1;
            const endIdx = Math.min(currentPage * rowsPerPage, allRows.length);
            document.getElementById('paginationInfo').textContent = `Showing ${allRows.length > 0 ? startIdx : 0}-${endIdx} of ${allRows.length} entries`;
        }

        function renderVisibleRows() {
            const start = (currentPage - 1) * rowsPerPage;
            const end = start + rowsPerPage;

            allRows.forEach((row, index) => {
                if (index >= start && index < end) {
                    row.cells[0].textContent = index + 1;
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        }

        function goToPage(page) {
            const totalPages = Math.ceil(allRows.length / rowsPerPage) || 1;
            if (page < 1 || page > totalPages) return;
            currentPage = page;
            renderVisibleRows();
            updatePagination();
        }

        document.getElementById('pageSizeSelect').addEventListener('change', function() {
            rowsPerPage = parseInt(this.value);
            currentPage = 1;
            filterTable();
        });

        function editRecharge(id, amount, date, description) {
            document.getElementById('editRechargeId').value = id;
            document.getElementById('editRechargeAmount').value = amount;
            document.getElementById('editRechargeDate').value = date;
            document.getElementById('editRechargeDescription').value = description || '';
            new bootstrap.Modal(document.getElementById('editRechargeModal')).show();
        }

        function viewRecharge(id, amount, date) {
            document.getElementById('viewId').textContent = '#' + id;
            document.getElementById('viewAmount').textContent = '₹' + parseFloat(amount).toLocaleString('en-IN', {minimumFractionDigits: 2});
            document.getElementById('viewDate').textContent = date;
            new bootstrap.Modal(document.getElementById('viewRechargeModal')).show();
        }

        function deleteRecharge(id) {
            document.getElementById('deleteRechargeId').value = id;
            new bootstrap.Modal(document.getElementById('deleteRechargeModal')).show();
        }

        initPagination();
    </script>
}
