@using System.Web
@model IEnumerable<ExpenseManager.Application.DTOs.ExpenseDto>
@{
    ViewData["Title"] = "All expense";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0">Expense History</h3>
            <p class="text-muted small mb-0">Track and manage all your office expenditures</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <button id="bulkDeleteBtn" class="btn btn-outline-danger d-none d-flex align-items-center p-1" onclick="confirmBulkDelete()">
                <i class="bi bi-trash pe-1"></i> Delete Selected(<span id="selectedCount">0</span>)
            </button>
            <a asp-action="Create" class="btn btn-teal d-flex align-items-center gap-2">
                <i class="bi bi-plus-lg"></i> Add Expense
            </a>
        </div>
    </div>

    <div class="custom-card mb-2">
        <div class="row g-3 align-items-center">
            <div class="col-md-3">
                <div class="filter-input-group">
                    <i class="bi bi-search"></i>
                    <input type="text" id="searchInput" placeholder="Search expenses...">
                </div>
            </div>
            <div class="col-md-4">
                <div class="filter-input-group">
                    <!-- <i class="bi bi-calendar3 me-2"></i> -->
                    <!-- <label for="dateFrom">From </label> -->
                     <span class="text-muted px-2">from</span>
                    <input type="date" id="dateFrom" title="From Date">
                    <span class="text-muted px-2">to</span>
                    <!-- <label for="dateTo">To Date</label> -->
                    <input type="date" id="dateTo" title="To Date">
                </div>
            </div>
            <div class="col-md-2">
                <div class="filter-input-group p-0 m-0">
                    <i class="bi bi-tag me-2 d-none"></i>
                    <select id="categoryFilter">
                        <option value="">All Categories</option>
                        @foreach (var cat in Model.Select(e => e.CategoryName).Distinct())
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-3 text-end">
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="ExportData" class="btn-icon-circle" title="Export Data">
                        <i class="bi bi-download"></i>
                    </a>
                    <button class="btn-icon-circle d-none" title="Advanced Filters">
                        <i class="bi bi-funnel"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="standard-table-container">
        <div class="table-body-scroll-limit">
            <table class="standard-table" id="expensesTable">
            <thead>
                <tr>
                    <th class="text-center" style="width: 50px;">
                        <div class="form-check d-flex justify-content-center">
                            <input class="form-check-input" type="checkbox" id="selectAllCheckbox" onclick="toggleSelectAll()">
                        </div>
                    </th>
                    <th class="text-center" style="width: 80px;">s.no</th>
                    <th>Expense Details</th>
                     <th>Date</th>
                    <th>category</th>
                    <th class="">Amount</th>
                    <th class="">Payment Method</th>
                    <th class="">Vendor Name</th>
                    <th class="text-center">receipt</th>
                    <th class="text-end" style="width: 150px;">actions</th>
                </tr>
            </thead>
            <tbody>
                <tr id="noDataRow" style="display: none;">
                    <td colspan="8" class="text-center py-5">
                        <div class="text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                            <h5 class="fw-bold">No data found</h5>
                            <p class="small mb-0">No expenses match your current filters. Try adjusting your search or dates.</p>
                        </div>
                    </td>
                </tr>
                @foreach (var item in Model)
                {
                    <tr data-id="@item.Id">
                        <td class="text-center">
                            <div class="form-check d-flex justify-content-center">
                                <input class="form-check-input item-checkbox" type="checkbox" value="@item.Id" onclick="updateSelection()">
                            </div>
                        </td>
                        <td class="text-center fw-medium text-muted sno-cell"></td>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                               
                                <div>
                                    <div class="fw-bold text-dark" style="text-transform: capitalize">@item.Title</div>
                                    <!-- <small class="text-muted">@item.Date.ToString("dd MMM yyyy")</small> -->
                                    <!-- <div class="d-none expense-description">@item.Description</div> -->
                                </div>
                            </div>
                            <div class="d-none filter-date">@item.Date.ToString("dd/MM/yyyy")</div> <!-- Hidden for script filtering -->
                        </td>
                        <td class="text-muted">@item.Date.ToString("dd MMM yyyy")</td>
                        <td>
                            <span class="badge-pill-standard badge-active">
                                <span class="dot"></span>
                                @item.CategoryName
                            </span>
                        </td>
                        <td class="fw-bold text-dark">₹@(item.Amount?.ToString("N2") ?? "0.00")</td>
                        <td class="text-muted">
                           @if (string.IsNullOrEmpty(item.PaymentMethod))
                                {
                                    <span class="text-muted empty-payment-method">No Payment method</span>
                                }
                                else
                                {
                                    <span class="text-muted">@item.PaymentMethod</span>
                                }
                        </td>
                        <td class="text-muted">@(string.IsNullOrEmpty(item.VendorName) ? "-" : item.VendorName)</td>
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(item.ReceiptPath))
                            {
                                <button type="button" class="btn-icon-circle mx-auto" 
                                        onclick="showReceiptPreview('@Html.Raw(HttpUtility.JavaScriptStringEncode(item.ReceiptPath))')" 
                                        title="View Receipt">
                                    <i class="bi bi-file-earmark-image"></i>
                                </button>
                            }
                            else
                            {
                                <span class="text-muted small">No receipt</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <!-- <button type="button" class="btn-icon-circle text-primary" 
                                        onclick="viewExpenseDetails({ 
                                            id: '@item.Id', 
                                            title: '@Html.Raw(HttpUtility.JavaScriptStringEncode(item.Title))', 
                                            description: '@Html.Raw(HttpUtility.JavaScriptStringEncode(item.Description ?? ""))',
                                            amount: '@item.Amount', 
                                            date: '@item.Date.ToString("yyyy-MM-dd")', 
                                            category: '@Html.Raw(HttpUtility.JavaScriptStringEncode(item.CategoryName))', 
                                            categoryId: '@item.CategoryId',
                                            paymentMethod: '@Html.Raw(HttpUtility.JavaScriptStringEncode(item.PaymentMethod ?? "N/A"))',
                                            receiptPath: '@Html.Raw(HttpUtility.JavaScriptStringEncode(item.ReceiptPath))'
                                        })" title="View">
                                    <i class="bi bi-eye"></i>
                                </button> -->
                                <button type="button" class="btn-icon-circle" 
                                        onclick="editExpense({ 
                                            id: '@item.Id', 
                                            title: '@Html.Raw(HttpUtility.JavaScriptStringEncode(item.Title))', 
                                            amount: '@item.Amount', 
                                            date: '@item.Date.ToString("yyyy-MM-dd")', 
                                            categoryId: '@item.CategoryId', 
                                            paymentMethod: '@Html.Raw(HttpUtility.JavaScriptStringEncode(item.PaymentMethod ?? ""))',
                                            vendorName: '@Html.Raw(HttpUtility.JavaScriptStringEncode(item.VendorName ?? ""))'
                                        })" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button type="button" class="btn-icon-circle text-danger" onclick="confirmDeleteExpense('@item.Id')" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
        <div class="pagination-container rounded-bottom shadow-sm">
        <div class="small fw-medium text-muted" id="paginationInfo">
            Showing 1-10 of 100 entries
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center gap-2 me-4">
                <span class="small text-muted fw-medium">Rows per page:</span>
                <select id="pageSizeSelect" class="form-select form-select-sm border-0 bg-light" style="width: 70px; border-radius: 6px;">
                    <option value="10" selected>10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                </select>
            </div>
            <div class="d-flex gap-1" id="paginationControls">
                <!-- Navigation buttons will be injected here -->
            </div>
        </div>
    </div>
    </div>

    
</div>

<!-- Enhanced Receipt Preview Modal -->
<div class="modal fade" id="receiptModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 12px; overflow: hidden;">
            <div class="modal-header bg-white border-bottom-1">
                <h5 class="modal-title fw-bold">Receipt View</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0 bg-light">
                <div class="receipt-zoom-viewport" id="receiptViewport">
                    <img id="receiptFullImage" src="" class="receipt-zoom-image" />
                    <div class="zoom-controls">
                        <button class="zoom-btn" onclick="zoomReceipt(0.2)" title="Zoom In">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                        <button class="zoom-btn" onclick="zoomReceipt(-0.2)" title="Zoom Out">
                            <i class="bi bi-dash-lg"></i>
                        </button>
                        <button class="zoom-btn" onclick="resetReceiptZoom()" title="Reset">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </button>
                    </div>
                </div>
                <div id="pdfContainer" class="d-none">
                    <iframe id="receiptFullPdf" src="" class="w-100" style="height: 80vh; border: none;"></iframe>
                </div>
            </div>
            <div class="modal-footer bg-white border-top-1">
                <a id="downloadFullReceipt" href="#" class="btn btn-primary px-4 shadow-sm" download style="background-color: #1e3a8a; border: none; border-radius: 8px;">
                    <i class="bi bi-download me-2"></i> Download Receipt
                </a>
                <button type="button" class="btn btn-light px-4 border" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Expense Detail Modal -->
<div class="modal fade" id="expenseDetailModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content modal-content-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title modal-title-custom">Expense Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4" >
                <div class="row g-4" style="font-size: 14px;">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="small text-muted fw-bold">Title</label>
                            <div id="detailTitle" class="fw-bold  text-dark" style="text-transform: capitalize;"></div>
                        </div>
                        <div class="mb-3">
                            <label class="small text-muted fw-bold">Description</label>
                            <div id="detailDescription" class="text-dark small"></div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="small text-muted fw-bold">Amount</label>
                                <div id="detailAmount" class="fw-bold text-primary"></div>
                            </div>
                            <div class="col-6">
                                <label class="small text-muted fw-bold">Date</label>
                                <div id="detailDate"></div>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="small text-muted fw-bold">Category</label>
                                <div><span id="detailCategory" class="badge-category"></span></div>
                            </div>
                            <div class="col-6">
                                <label class="small text-muted fw-bold">Payment Method</label>
                                <div id="detailPaymentMethod"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 border-start">
                        <label class="small text-muted fw-bold mb-2">Receipt Preview</label>
                        <div id="receiptPreviewContainer" class="text-center bg-light rounded-3 p-3 overflow-hidden" style="min-height: 200px; display: flex; align-items: center; justify-content: center;">
                            <span id="noReceiptMsg" class="text-muted small">No receipt uploaded</span>
                            <img id="receiptImg" src="" class="img-fluid d-none" style="max-height: 250px;" />
                            <iframe id="receiptPdf" src="" class="w-100 d-none" style="height: 250px;"></iframe>
                        </div>
                        <div id="receiptDownloadLink" class="text-center mt-2 d-none">
                            <a href="#" class="btn btn-sm btn-outline-primary" download><i class="bi bi-download"></i> Download Receipt</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer modal-footer-custom">
                <div class="me-auto">
                    <button id="editLink" type="button" class="btn btn-modal-secondary btn-sm px-3"><i class="bi bi-pencil me-1"></i> Edit</button>
                    <form id="deleteForm" method="post" class="d-inline ms-1">
                        <button type="submit" class="btn btn-modal-danger btn-sm px-3"><i class="bi bi-trash me-1"></i> Delete</button>
                    </form>
                </div>
                <button type="button" class="btn btn-modal-secondary px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Expense Modal -->
<div class="modal fade" id="editExpenseModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title modal-title-custom">Edit Expense</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editExpenseForm" asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" name="Id" id="editId" />
                <div class="modal-body px-4 py-2">
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">DATE</label>
                            <input type="date" name="Date" id="editDate" class="form-control form-control-custom" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">AMOUNT (₹)</label>
                            <input type="number" step="0.01" name="Amount" id="editAmount" class="form-control form-control-custom" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">DESCRIPTION</label>
                        <input type="text" name="Title" id="editTitle" class="form-control form-control-custom" required />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">CATEGORY</label>
                            <select name="CategoryId" id="editCategoryId" class="form-select form-control-custom" required>
                                @foreach (var cat in (IEnumerable<SelectListItem>)ViewBag.CategoriesList)
                                {
                                    <option value="@cat.Value">@cat.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">PAYMENT METHOD</label>
                            <select name="PaymentMethod" id="editPaymentMethod" class="form-select form-control-custom">
                                <option value="">Select Method</option>
                                <option value="Cash">Cash</option>
                                <option value="Credit Card">Credit Card</option>
                                <option value="Debit Card">Debit Card</option>
                                <option value="UPI">UPI</option>
                                <option value="Net Banking">Net Banking</option>
                                <option value="Wallet">Wallet</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">VENDOR (OPTIONAL)</label>
                        <input type="text" name="VendorName" id="editVendorName" class="form-control form-control-custom" placeholder="Enter vendor name" />
                    </div>
                    <div class="mb-0">
                        <label class="form-label small fw-bold text-muted">RECEIPT (OPTIONAL)</label>
                        <input type="file" name="ReceiptFile" class="form-control form-control-custom" accept=".png,.jpg,.jpeg,.pdf" />
                        <small class="text-muted">Leave empty to keep current receipt</small>
                    </div>
                </div>
                <div class="modal-footer modal-footer-custom">
                    <button type="button" class="btn btn-modal-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-modal-primary">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteExpenseModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title modal-title-custom">Confirm Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="deleteExpenseForm" asp-action="Delete" method="post">
                <input type="hidden" name="id" id="deleteId" />
                <div class="modal-body p-4">
                    <p class="mb-0">Are you sure you want to delete this expense? This action cannot be undone.</p>
                </div>
                <div class="modal-footer modal-footer-custom">
                    <button type="button" class="btn btn-modal-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-modal-danger px-4">Delete Permanently</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Bulk Delete Confirmation Modal -->
<div class="modal fade" id="bulkDeleteModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-custom">
            <div class="modal-header modal-header-custom">
                <h5 class="modal-title modal-title-custom">Confirm Bulk Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <p class="mb-0">Are you sure you want to delete <span id="bulkDeleteCount" class="fw-bold"></span> expenses? This action cannot be undone.</p>
            </div>
            <div class="modal-footer modal-footer-custom">
                <button type="button" class="btn btn-modal-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-modal-danger px-4" onclick="executeBulkDelete()">Delete Permanently</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const expenseModal = new bootstrap.Modal(document.getElementById('expenseDetailModal'));
        const editModal = new bootstrap.Modal(document.getElementById('editExpenseModal'));
        const deleteModal = new bootstrap.Modal(document.getElementById('deleteExpenseModal'));
        const bulkDeleteModal = new bootstrap.Modal(document.getElementById('bulkDeleteModal'));
        let rowsPerPage = 10;
        let currentPage = 1;
        let filteredRows = [];
        let selectedIds = [];

        // Receipt Preview logic
        const receiptModalInstance = new bootstrap.Modal(document.getElementById('receiptModal'));
        let currentScale = 1;
        let isDragging = false;
        let startX, startY, moveX = 0, moveY = 0;
        const receiptFullImg = document.getElementById('receiptFullImage');
        const receiptViewport = document.getElementById('receiptViewport');

        function showReceiptPreview(path) {
            const isPdf = path.toLowerCase().endsWith('.pdf');
            const pdfContainer = document.getElementById('pdfContainer');
            const downloadBtn = document.getElementById('downloadFullReceipt');
            
            downloadBtn.href = path;

            if (isPdf) {
                receiptViewport.classList.add('d-none');
                pdfContainer.classList.remove('d-none');
                document.getElementById('receiptFullPdf').src = path;
            } else {
                receiptViewport.classList.remove('d-none');
                pdfContainer.classList.add('d-none');
                receiptFullImg.src = path;
                resetReceiptZoom();
            }
            receiptModalInstance.show();
        }

        function zoomReceipt(delta) {
            currentScale = Math.max(0.5, Math.min(5, currentScale + delta));
            updateReceiptTransform();
        }

        function resetReceiptZoom() {
            currentScale = 1;
            moveX = 0;
            moveY = 0;
            updateReceiptTransform();
        }

        function updateReceiptTransform() {
            receiptFullImg.style.transform = `translate(calc(-50% + ${moveX}px), calc(-50% + ${moveY}px)) scale(${currentScale})`;
        }

        // Pan logic
        receiptViewport.addEventListener('mousedown', (e) => {
            if (currentScale > 1) {
                isDragging = true;
                startX = e.pageX - moveX;
                startY = e.pageY - moveY;
            }
        });

        window.addEventListener('mousemove', (e) => {
            if (!isDragging) return;
            e.preventDefault();
            moveX = e.pageX - startX;
            moveY = e.pageY - startY;
            updateReceiptTransform();
        });

        window.addEventListener('mouseup', () => {
            isDragging = false;
        });

        // Mouse wheel zoom
        receiptViewport.addEventListener('wheel', (e) => {
            e.preventDefault();
            const delta = e.deltaY > 0 ? -0.1 : 0.1;
            zoomReceipt(delta);
        });

        function viewExpenseDetails(data) {
            console.log("Viewing expense:", data);
            
            const title = data.title || '';
            const description = data.description || 'N/A';
            const amount = data.amount || 0;
            const date = data.date || '';
            const category = data.category || 'N/A';
            const paymentMethod = data.paymentMethod || 'N/A';
            const receiptPath = data.receiptPath || data.receipt || '';
            const id = data.id;

            document.getElementById('detailTitle').textContent = title;
            document.getElementById('detailDescription').textContent = description;
            document.getElementById('detailAmount').textContent = '₹' + parseFloat(amount).toLocaleString('en-IN', { minimumFractionDigits: 2 });
            document.getElementById('detailDate').textContent = date;
            document.getElementById('detailCategory').textContent = category;
            document.getElementById('detailPaymentMethod').textContent = paymentMethod;
 
            document.getElementById('editLink').onclick = function() {
                expenseModal.hide();
                editExpense({
                    id: id,
                    title: title,
                    amount: amount,
                    date: date,
                    categoryId: data.categoryId,
                    paymentMethod: paymentMethod === 'N/A' ? '' : paymentMethod
                });
            };
            document.getElementById('deleteForm').onsubmit = function(e) {
                e.preventDefault();
                expenseModal.hide();
                confirmDeleteExpense(id);
                return false;
            };

            const previewContainer = document.getElementById('receiptPreviewContainer');
            const noReceiptMsg = document.getElementById('noReceiptMsg');
            const receiptImg = document.getElementById('receiptImg');
            const receiptPdf = document.getElementById('receiptPdf');
            const downloadLink = document.getElementById('receiptDownloadLink');

            noReceiptMsg.classList.remove('d-none');
            receiptImg.classList.add('d-none');
            receiptPdf.classList.add('d-none');
            downloadLink.classList.add('d-none');

            if (receiptPath && receiptPath !== '') {
                noReceiptMsg.classList.add('d-none');
                downloadLink.classList.remove('d-none');
                downloadLink.querySelector('a').href = receiptPath;
 
                if (receiptPath.toLowerCase().endsWith('.pdf')) {
                    receiptPdf.src = receiptPath;
                    receiptPdf.classList.remove('d-none');
                } else {
                    receiptImg.src = receiptPath;
                    receiptImg.classList.remove('d-none');
                }
            }
            expenseModal.show();
        }

        function editExpense(data) {
            document.getElementById('editId').value = data.id;
            document.getElementById('editTitle').value = data.title;
            document.getElementById('editAmount').value = data.amount;
            document.getElementById('editDate').value = data.date;
            document.getElementById('editCategoryId').value = data.categoryId;
            document.getElementById('editPaymentMethod').value = data.paymentMethod;
            document.getElementById('editVendorName').value = data.vendorName;
            editModal.show();
        }

        function confirmDeleteExpense(id) {
            document.getElementById('deleteId').value = id;
            deleteModal.show();
        }

        document.getElementById('searchInput').addEventListener('keyup', () => { currentPage = 1; filterTable(); });
        document.getElementById('categoryFilter').addEventListener('change', () => { currentPage = 1; filterTable(); });
        document.getElementById('dateFrom').addEventListener('change', () => { currentPage = 1; filterTable(); });
        document.getElementById('dateTo').addEventListener('change', () => { currentPage = 1; filterTable(); });
        document.getElementById('pageSizeSelect').addEventListener('change', function() {
            rowsPerPage = parseInt(this.value);
            currentPage = 1;
            filterTable();
        });

        function filterTable() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const category = document.getElementById('categoryFilter').value.toLowerCase();
            const fromDateStr = document.getElementById('dateFrom').value;
            const toDateStr = document.getElementById('dateTo').value;
            
            const fromDate = fromDateStr ? new Date(fromDateStr) : null;
            if (fromDate) fromDate.setHours(0,0,0,0);
            
            const toDate = toDateStr ? new Date(toDateStr) : null;
            if (toDate) toDate.setHours(23, 59, 59, 999);

            const allRows = Array.from(document.querySelectorAll('#expensesTable tbody tr:not(#noDataRow)'));
            
            filteredRows = allRows.filter(row => {
                const detailsContainer = row.cells[2];
                const title = detailsContainer.querySelector('.fw-bold').textContent.toLowerCase().trim();
                const dateText = detailsContainer.querySelector('.filter-date').textContent.trim(); // dd/MM/yyyy
                const cat = row.cells[4].textContent.toLowerCase().trim();
                
                const dateParts = dateText.split('/');
                const rowDate = new Date(dateParts[2], dateParts[1] - 1, dateParts[0]);

                const matchesSearch = title.includes(search) || cat.includes(search);
                const matchesCategory = category === "" || cat.includes(category);
                
                let matchesFrom = true;
                if (fromDate) {
                    matchesFrom = rowDate >= fromDate;
                }
                
                let matchesTo = true;
                if (toDate) {
                    matchesTo = rowDate <= toDate;
                }

                return matchesSearch && matchesCategory && matchesFrom && matchesTo;
            });

            allRows.forEach(row => row.style.display = "none");
            
            updatePagination();
            renderVisibleRows();
        }

        function updatePagination() {
            const totalPages = Math.ceil(filteredRows.length / rowsPerPage) || 1;
            const controls = document.getElementById('paginationControls');
            controls.innerHTML = '';

            const prevBtn = document.createElement('button');
            prevBtn.className = `page-btn ${currentPage === 1 ? 'disabled' : ''}`;
            prevBtn.innerHTML = '<i class="bi bi-chevron-left"></i> Previous';
            prevBtn.disabled = currentPage === 1;
            prevBtn.onclick = () => goToPage(currentPage - 1);
            controls.appendChild(prevBtn);

            for (let i = 1; i <= totalPages; i++) {
                const pageBtn = document.createElement('button');
                pageBtn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
                pageBtn.textContent = i;
                pageBtn.onclick = () => goToPage(i);
                controls.appendChild(pageBtn);
            }

            // const pageNum = document.createElement('button');
            // pageNum.className = 'page-btn active';
            // pageNum.textContent = currentPage;
            // controls.appendChild(pageNum);

            const nextBtn = document.createElement('button');
            nextBtn.className = `page-btn ${currentPage === totalPages ? 'disabled' : ''}`;
            nextBtn.innerHTML = 'Next <i class="bi bi-chevron-right"></i>';
            nextBtn.disabled = currentPage === totalPages;
            nextBtn.onclick = () => goToPage(currentPage + 1);
            controls.appendChild(nextBtn);

            const startIdx = (currentPage - 1) * rowsPerPage + 1;
            const endIdx = Math.min(currentPage * rowsPerPage, filteredRows.length);
            document.getElementById('paginationInfo').textContent = `Showing ${filteredRows.length > 0 ? startIdx : 0}-${endIdx} of ${filteredRows.length} entries`;
            
            const paginationContainer = document.querySelector('.pagination-container');
            if (filteredRows.length === 0) {
                paginationContainer.style.display = 'none';
            } else {
                paginationContainer.style.display = 'flex';
            }
        }

        // function renderVisibleRows() {
        //     const start = (currentPage - 1) * rowsPerPage;
        //     const end = start + rowsPerPage;
        //     filteredRows.slice(start, end).forEach((row, index) => {
        //         row.cells[0].textContent = start + index + 1;
        //         row.style.display = "";
        //     });
        // }
        function renderVisibleRows() {
            const start = (currentPage - 1) * rowsPerPage;
            const end = start + rowsPerPage;
            const noDataRow = document.getElementById('noDataRow');

            // First hide ALL filtered rows
            filteredRows.forEach(row => {
                row.style.display = "none";
            });

            if (filteredRows.length === 0) {
                noDataRow.style.display = "";
            } else {
                noDataRow.style.display = "none";
                // Show only current page rows and assign serial numbers
                filteredRows.slice(start, end).forEach((row, index) => {
                    const snoCell = row.querySelector('.sno-cell');
                    if (snoCell) snoCell.textContent = start + index + 1;
                    row.style.display = "";
                });
            }
        }

        // function goToPage(page) {
        //     currentPage = page;
        //     renderVisibleRows();
        //     updatePagination();
        // }


        function goToPage(page) {
    const totalPages = Math.ceil(filteredRows.length / rowsPerPage) || 1;

    if (page < 1 || page > totalPages) return; // ✅ prevent overflow

    currentPage = page;
    renderVisibleRows();
    updatePagination();
}

        // Bulk Selection Logic
        function toggleSelectAll() {
            const selectAll = document.getElementById('selectAllCheckbox');
            const checkboxes = document.querySelectorAll('.item-checkbox');
            const visibleRows = filteredRows.filter(row => row.style.display !== 'none');
            
            checkboxes.forEach(cb => {
                const row = cb.closest('tr');
                if (row.style.display !== 'none') {
                    cb.checked = selectAll.checked;
                }
            });
            updateSelection();
        }

        function updateSelection() {
            const checkboxes = document.querySelectorAll('.item-checkbox:checked');
            selectedIds = Array.from(checkboxes).map(cb => parseInt(cb.value));
            
            const bulkBtn = document.getElementById('bulkDeleteBtn');
            const selectedCount = document.getElementById('selectedCount');
            
            if (selectedIds.length > 0) {
                bulkBtn.classList.remove('d-none');
                selectedCount.textContent = selectedIds.length;
            } else {
                bulkBtn.classList.add('d-none');
            }
            
            // Update Select All checkbox state
            const allVisibleCheckboxes = document.querySelectorAll('.item-checkbox');
            const visibleCheckboxes = Array.from(allVisibleCheckboxes).filter(cb => cb.closest('tr').style.display !== 'none');
            const allChecked = visibleCheckboxes.length > 0 && visibleCheckboxes.every(cb => cb.checked);
            document.getElementById('selectAllCheckbox').checked = allChecked;
        }

        function confirmBulkDelete() {
            document.getElementById('bulkDeleteCount').textContent = selectedIds.length;
            bulkDeleteModal.show();
        }

        async function executeBulkDelete() {
            try {
                const response = await fetch('/Expense/BulkDelete', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(selectedIds)
                });

                if (response.ok) {
                    location.reload();
                } else {
                    alert('Failed to delete expenses. Please try again.');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            }
        }

        // Init
        filterTable();
    </script>
}
