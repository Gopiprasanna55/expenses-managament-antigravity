@model IEnumerable<ExpenseManager.Application.DTOs.CategoryDto>
@{
    ViewData["Title"] = "Categories";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">Expense Categories</h3>
            <p class="text-muted small mb-0">Organize and manage your expense types</p>
        </div>
        <a asp-action="Create" class="btn btn-teal d-flex align-items-center gap-2">
            <i class="bi bi-plus-lg"></i> Add Category
        </a>
    </div>

    <div class="standard-table-container">
        <table class="standard-table">
            <thead>
                <tr>
                    <th>CATEGORY INFORMATION</th>
                    <th>CREATED DATE</th>
                    <th>STATUS</th>
                    <th class="text-end" style="width: 150px;">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                
                                <div>
                                    <div class="fw-bold text-dark" style="text-transform: capitalize;">@item.Name</div>
                                   
                                </div>
                            </div>
                        </td>
                        <td class="text-muted">@item.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <span class="badge-pill-standard @(item.IsActive ? "badge-active" : "badge-inactive")">
                                <span class="dot"></span>
                                @(item.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon-circle" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon-circle text-primary" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
