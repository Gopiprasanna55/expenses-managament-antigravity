@model ExpenseManager.Application.DTOs.CategoryDto
@{
    ViewData["Title"] = "Update Category";
}

<div class="container d-flex justify-content-center">
    <div class="custom-card col-md-6 p-4">
        <h4 class="fw-bold mb-1">Update Category</h4>
        <p class="text-muted small mb-4">Modify category properties for: @Model.Name</p>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
            
            <div class="mb-4">
                <label asp-for="Name" class="form-label small fw-bold text-muted"><i class="bi bi-tag"></i> CATEGORY NAME</label>
                <input asp-for="Name" class="form-control form-control-custom" placeholder="e.g. Subscriptions" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <div class="form-check form-switch p-0 d-flex align-items-center gap-3">
                    <label asp-for="IsActive" class="form-label small fw-bold text-muted mb-0">ENABLED STATUS</label>
                    <input asp-for="IsActive" class="form-check-input ms-0" type="checkbox" role="switch">
                </div>
            </div>

            <div class="d-flex justify-content-end gap-3 mt-5">
                <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 8px;">Cancel</a>
                <button type="submit" class="btn btn-primary px-4 py-2" style="background-color: #1e3a8a; border: none; border-radius: 8px;">Update Category</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
