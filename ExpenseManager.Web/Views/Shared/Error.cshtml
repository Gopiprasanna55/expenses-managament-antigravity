@model ExpenseManager.Web.ViewModels.ErrorViewModel
@{
    ViewData["Title"] = "Application Error";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="custom-card text-center p-5 col-md-6 shadow-sm">
        <div class="bg-light-red d-inline-flex align-items-center justify-content-center rounded-circle mb-4" style="width: 80px; height: 80px;">
            <i class="bi bi-exclamation-triangle fs-1"></i>
        </div>
        <h3 class="fw-bold mb-3">Something went wrong</h3>
        <p class="text-muted mb-4">An unexpected error occurred while processing your request. Our technical team has been notified.</p>
        
        @if (Model != null && Model.ShowRequestId)
        {
            <div class="bg-light p-3 rounded-3 mb-4 text-start">
                <small class="text-muted d-block uppercase fw-bold mb-1" style="font-size: 0.7rem;">SYSTEM TRACKING ID</small>
                <code class="text-dark">@Model.RequestId</code>
            </div>
        }

        <div class="d-flex gap-2 justify-content-center">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4 py-2" style="background-color: #1e3a8a; border: none; border-radius: 8px;">
                <i class="bi bi-house-door me-2"></i> Go to Dashboard
            </a>
            <button onclick="window.location.reload()" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 8px;">
                <i class="bi bi-arrow-clockwise me-2"></i> Try Again
            </button>
        </div>
    </div>
</div>
